# Django Configuration - Copy this file to .env and fill in the values
# NEVER commit .env to version control

# ========== SECURITY ==========
# Generate a new SECRET_KEY using: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secret-key-here-generate-with-django-command

# Environment: development or production
DEBUG=False
ENVIRONMENT=production

# ========== DATABASE ==========
# For local development with PostgreSQL:
# DATABASE_URL=postgresql://jamarik_user:password@localhost:5432/jamarik_db

# For Render: This will be auto-generated - do not set locally

# ========== EMAIL CONFIGURATION ==========
# Gmail SMTP configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
DEFAULT_FROM_EMAIL=noreply@jamarik.com
CONTACT_EMAIL=info@jamarik.com

# ========== ALLOWED HOSTS ==========
# For local development, Render will auto-configure this
# Add your domain here if testing locally
ALLOWED_HOSTS=localhost,127.0.0.1,jamariktechnologies.onrender.com

# ========== MEDIA FILES ==========
# If using cloud storage (optional):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=

# ========== STATIC FILES ==========
# Handled by WhiteNoise - no configuration needed
